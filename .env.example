# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=
# Optional: per-request ceiling for server Supabase HTTP (ms). Large Storage uploads need a high value; default 600000.
# SUPABASE_HTTP_TIMEOUT_MS=
# Max final-render upload size (bytes). Must be ≤ Supabase Dashboard → Storage global file size limit (default 50 MiB matches supabase/config.toml).
# RETOOL_MAX_RENDER_UPLOAD_BYTES=

# Stripe (Dashboard → Developers → API keys; use test keys locally)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Subscription Checkout: create a recurring Price in Stripe Dashboard, paste its price_… id
STRIPE_PRICE_ID=

# Apify — listing ingest (server-only). Actor: maxcopell/zillow-detail-scraper
# https://apify.com/maxcopell/zillow-detail-scraper
APIFY_API_TOKEN=
# Optional — e.g. dashboard links / logging only; not required for REST calls
APIFY_USER_ID=

# Fal.ai — image→video for scene clips (server-only). See https://fal.ai
FAL_AI_KEY=
# Optional — defaults to fal-ai/kling-video/v2.1/standard/image-to-video
FAL_SCENE_VIDEO_MODEL=
# Parallel scene jobs per wave (default 3, max 8). Use 1 to force serial.
# SCENE_VIDEO_CONCURRENCY=
# How long Fal keeps each output file on fal.media (presets: 1h, 1d, 7d, 30d, 1y, never, or seconds as integer). Default 30d.
# FAL_OUTPUT_MEDIA_EXPIRES_IN=
# Kling image-to-video: reduce hallucinated rooms/objects (defaults are conservative)
# FAL_SCENE_VIDEO_CFG_SCALE=0.45
# FAL_SCENE_VIDEO_NEGATIVE_PROMPT=
# FAL_SCENE_VIDEO_PROMPT=

# Force placeholder scene_video jobs even when FAL_AI_KEY is set (local testing)
USE_MOCK_VIDEO=

# Final video compose (FFmpeg on the server). Unset or `1` / `true` uses FFmpeg when `ffmpeg` is on PATH (concat all clips, mux voice/music, optional captions).
# Set to `0` to force preview export (first clip only, no voice/music/captions).
# Requires ffmpeg on PATH or FFMPEG_PATH. Compose jobs defer via `after()` when FFmpeg compose is on.
ENABLE_COMPOSE=
# FFMPEG_PATH=

# If Apify fails, still save a stub snapshot (dev escape hatch)
LISTING_INGEST_FALLBACK_STUB=

# Vercel cron / manual: Authorization: Bearer <secret> for GET /api/cron/process-jobs
# (drains scene_video jobs until ~270s per request — use a 1–2 min schedule for long queues)
CRON_SECRET=

# OpenAI — listing voiceover script generation (server-only). Optional: OPENAI_SCRIPT_MODEL (default gpt-4o-mini)
OPEN_AI_SECRET=
# Legacy alias; app reads OPEN_AI_SECRET first
# OPENAI_API_KEY=

# Eleven Labs — TTS / voices / music (server-only). Value is your API key from the dashboard.
# Captions use Forced Alignment: the key must include the **Forced Alignment** permission (Dashboard → Developers → API keys → edit key → enable it). Keys scoped only to TTS will return 401 missing_permissions.
ELEVEN_LABS_KEY_ID=
# ELEVENLABS_API_KEY=
# Optional TTS model for previews & generation (default eleven_multilingual_v2)
# ELEVENLABS_TTS_MODEL=
# Music compose (POST /v1/music): default music_v1; output e.g. mp3_44100_128 (see ElevenLabs docs)
# ELEVENLABS_MUSIC_MODEL=
# ELEVENLABS_MUSIC_OUTPUT_FORMAT=
# After app-side spoken normalization, Eleven's apply_text_normalization=on can mis-read ordinals; default is off/auto (see elevenlabs-tts.ts)
# ELEVENLABS_APPLY_TEXT_NORMALIZATION=on|auto|off
# Set to 1 to skip app-side spoken normalization only
# ELEVENLABS_TTS_SKIP_SPOKEN_NORMALIZE=