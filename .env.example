# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (Dashboard → Developers → API keys; use test keys locally)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Subscription Checkout: create a recurring Price in Stripe Dashboard, paste its price_… id
STRIPE_PRICE_ID=

# Apify — listing ingest (server-only). Actor: maxcopell/zillow-detail-scraper
# https://apify.com/maxcopell/zillow-detail-scraper
APIFY_API_TOKEN=
# Optional — e.g. dashboard links / logging only; not required for REST calls
APIFY_USER_ID=

# Fal.ai — image→video for scene clips (server-only). See https://fal.ai
FAL_AI_KEY=
# Optional — defaults to fal-ai/kling-video/v2.1/standard/image-to-video
FAL_SCENE_VIDEO_MODEL=

# Force mock scene_video jobs even when FAL_AI_KEY is set (local testing)
USE_MOCK_VIDEO=

# If Apify fails, still save a stub snapshot (dev escape hatch)
LISTING_INGEST_FALLBACK_STUB=

# Vercel cron / manual: Authorization: Bearer <secret> for GET /api/cron/process-jobs
CRON_SECRET=
# Optional batch size for cron (default 3)
CRON_SCENE_JOBS_BATCH=

# OpenAI — listing voiceover script generation (server-only). Optional: OPENAI_SCRIPT_MODEL (default gpt-4o-mini)
OPEN_AI_SECRET=
# Legacy alias; app reads OPEN_AI_SECRET first
# OPENAI_API_KEY=

# Eleven Labs — TTS / voices (server-only). Value is your API key from the dashboard.
ELEVEN_LABS_KEY_ID=
# ELEVENLABS_API_KEY=
# Optional TTS model for previews & generation (default eleven_multilingual_v2)
# ELEVENLABS_TTS_MODEL=
# After app-side spoken normalization, Eleven's apply_text_normalization=on can mis-read ordinals; default is off/auto (see elevenlabs-tts.ts)
# ELEVENLABS_APPLY_TEXT_NORMALIZATION=on|auto|off
# Set to 1 to skip app-side spoken normalization only
# ELEVENLABS_TTS_SKIP_SPOKEN_NORMALIZE=